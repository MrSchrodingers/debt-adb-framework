{
  "name": "debt-adb-framework",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n core,ui -c green,blue \"pnpm dev:core\" \"pnpm dev:ui\"",
    "dev:all": "concurrently -n core,ui,electron -c green,blue,magenta \"pnpm dev:core\" \"pnpm dev:ui\" \"sleep 5 && pnpm dev:electron\"",
    "dev:core": "npx tsx watch packages/core/src/main.ts",
    "dev:ui": "cd packages/ui && npx vite --host 0.0.0.0",
    "dev:electron": "cd packages/electron && pnpm dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "turbo": "^2.5.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.20.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  }
}
