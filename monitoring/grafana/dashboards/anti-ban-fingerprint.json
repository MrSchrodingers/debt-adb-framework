{
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "title": "Strategy Distribution (24h)",
      "type": "piechart",
      "gridPos": { "h": 10, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(increase(dispatch_messages_sent_total[24h])) by (method)", "legendFormat": "{{method}}", "refId": "A" }
      ]
    },
    {
      "title": "App Package Distribution (24h)",
      "type": "piechart",
      "gridPos": { "h": 10, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(increase(dispatch_messages_sent_total[24h])) by (app_package)", "legendFormat": "{{app_package}}", "refId": "A" }
      ]
    },
    {
      "title": "Send Duration by Strategy",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(dispatch_send_duration_seconds_bucket[5m])) by (le, method))", "legendFormat": "p50 {{method}}", "refId": "A" },
        { "expr": "histogram_quantile(0.90, sum(rate(dispatch_send_duration_seconds_bucket[5m])) by (le, method))", "legendFormat": "p90 {{method}}", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } } }
    },
    {
      "title": "Inter-Message Delay (First Contact vs Recurring)",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(dispatch_inter_message_delay_seconds_bucket{is_first_contact='true'}[5m])) by (le))", "legendFormat": "First Contact p50", "refId": "A" },
        { "expr": "histogram_quantile(0.50, sum(rate(dispatch_inter_message_delay_seconds_bucket{is_first_contact='false'}[5m])) by (le))", "legendFormat": "Recurring p50", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 15 } } }
    },
    {
      "title": "Hourly Volume Pattern",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(increase(dispatch_messages_sent_total[1h]))", "legendFormat": "Messages/hour", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 30, "drawStyle": "bars" } } }
    }
  ],
  "schemaVersion": 39,
  "tags": ["dispatch", "anti-ban"],
  "templating": {
    "list": [
      { "name": "DS_PROMETHEUS", "type": "datasource", "query": "prometheus", "current": { "selected": true, "text": "Prometheus", "value": "Prometheus" } }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "title": "Anti-Ban Fingerprint",
  "uid": "dispatch-anti-ban"
}
