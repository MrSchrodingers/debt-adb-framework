# ============================================================================
# Dispatch ADB Framework — Environment Configuration
# ============================================================================
# Copy to .env and set DISPATCH_API_KEY at minimum.
# All other vars have safe defaults for development.
# ============================================================================

# ── Core (required) ─────────────────────────────────────────────────────────
# API key for authenticating REST requests. REQUIRED in production/development.
DISPATCH_API_KEY=

# HTTP port for the Fastify server (default: 7890)
# PORT=7890

# SQLite database file path (default: dispatch.db)
# DB_PATH=dispatch.db

# Node environment: development | production | test (default: development)
# NODE_ENV=development

# Optional log file path (pino-roll). Omit for stdout-only.
# LOG_FILE=

# Comma-separated allowed CORS origins. Omit to allow all in dev.
# DISPATCH_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:7890

# ── WAHA (optional — passive listener) ──────────────────────────────────────
# WAHA API base URL. Omit to disable WAHA integration.
# WAHA_API_URL=https://waha.example.com

# WAHA API key for session management.
# WAHA_API_KEY=

# HMAC secret for validating incoming WAHA webhooks.
# WAHA_WEBHOOK_HMAC_SECRET=

# Public URL that WAHA should POST webhooks to.
# DISPATCH_WEBHOOK_URL=http://your-server:7890/api/v1/webhooks/waha

# ── Chatwoot (optional — inbox automation) ──────────────────────────────────
# Chatwoot API base URL. Omit to disable Chatwoot integration.
# CHATWOOT_API_URL=https://chatwoot.example.com

# Chatwoot API token for inbox/session management.
# CHATWOOT_API_TOKEN=

# Chatwoot account ID (default: 1)
# CHATWOOT_ACCOUNT_ID=1

# ── Rate Limiting ───────────────────────────────────────────────────────────
# Max messages per sender phone per calendar day (default: 150)
# MAX_PER_SENDER_PER_DAY=150

# Delay (ms) before sending to a first-time contact (default: 45000)
# FIRST_CONTACT_DELAY_MS=45000

# Delay (ms) between recurring contact messages (default: 15000)
# RECURRING_CONTACT_DELAY_MS=15000

# Jitter range (0-1) applied to delays. 0.3 = +/-30% (default: 0.3)
# RATE_LIMIT_JITTER=0.3

# ── Strategy Weights ────────────────────────────────────────────────────────
# Weights for send strategy selection. Must sum to 100 for best results.
# SEND_STRATEGY_PREFILL_WEIGHT=50
# SEND_STRATEGY_SEARCH_WEIGHT=30
# SEND_STRATEGY_TYPING_WEIGHT=20

# ── Quarantine ──────────────────────────────────────────────────────────────
# Number of consecutive failures before quarantining a sender (default: 3)
# QUARANTINE_AFTER_FAILURES=3

# Quarantine duration in ms (default: 3600000 = 1 hour)
# QUARANTINE_DURATION_MS=3600000

# ── Send Window (Phase 3 — future) ─────────────────────────────────────────
# Hour (0-23) when the send window opens (default: 7)
# SEND_WINDOW_START=7

# Hour (0-23) when the send window closes (default: 21)
# SEND_WINDOW_END=21

# Comma-separated day numbers: 1=Mon, 7=Sun (default: 1,2,3,4,5 = weekdays)
# SEND_WINDOW_DAYS=1,2,3,4,5

# Timezone offset in hours from UTC (default: -3 = BRT)
# SEND_WINDOW_OFFSET_HOURS=-3

# ── Screenshots (Phase 5 — future) ─────────────────────────────────────────
# Screenshot mode: all | sample | none (default: all)
# SCREENSHOT_MODE=all

# Sample rate when mode=sample, 0.0-1.0 (default: 0.1 = 10%)
# SCREENSHOT_SAMPLE_RATE=0.1

# Screenshot format: png | jpeg (default: png)
# SCREENSHOT_FORMAT=png

# Days to retain screenshots before cleanup (default: 7)
# SCREENSHOT_RETENTION_DAYS=7

# ── Plugins ─────────────────────────────────────────────────────────────────
# Comma-separated plugin names to load at boot (default: empty)
# DISPATCH_PLUGINS=oralsin

# Oralsin plugin webhook URL for callbacks.
# PLUGIN_ORALSIN_WEBHOOK_URL=http://localhost:8000/api/webhooks/dispatch/

# ── Circuit Breaker ─────────────────────────────────────────────────────────
# Number of consecutive ADB failures before opening the per-device circuit (default: 5)
# DISPATCH_CB_FAILURE_THRESHOLD=5

# Cooldown in ms before attempting a probe after circuit opens (default: 300000 = 5 min)
# DISPATCH_CB_COOLDOWN_MS=300000

# ── Backpressure (Task 4.4) ────────────────────────────────────────────────
# Reject incoming /enqueue calls with HTTP 429 + Retry-After: 30 when the
# queue's pending count exceeds this limit. (default: 1000)
# DISPATCH_QUEUE_DEPTH_LIMIT=1000

# ── Idempotency Cache (Task 4.3) ───────────────────────────────────────────
# TTL in seconds for plugin-enqueue idempotency_keys entries. Keys reserved
# within this window dedupe duplicate enqueues; expired keys are replaced.
# Hourly cleanup runs in main bootstrap. (default: 3600 = 1 hour)
# IDEMPOTENCY_CACHE_TTL_SEC=3600

# ── Smart Sender Selection (Task 5.2) ───────────────────────────────────────
# Multiplicative scoring: score = healthScore x inverseRecentFailures x timeSinceLastSend x roleWeight
# Quarantined and paused senders are always hard-filtered (score = 0).

# How aggressively recent consecutive failures penalise a sender.
# Formula: 1 / (1 + consecutive_failures^2 * failurePenalty)
# Higher value = harsher penalty. (default: 1.0)
# DISPATCH_SCORING_FAILURE_PENALTY=1.0

# Seconds of idle time at which the time-since-last-send factor saturates to 1.0.
# Idle senders score higher to spread load. After this threshold, no further bonus. (default: 3600)
# DISPATCH_SCORING_IDLE_SATURATION_SEC=3600

# Role priority weights. Must be in (0, 1]. Higher = preferred when scores are otherwise equal.
# DISPATCH_SCORING_WEIGHT_PRIMARY=1.0
# DISPATCH_SCORING_WEIGHT_OVERFLOW=0.7
# DISPATCH_SCORING_WEIGHT_BACKUP=0.5
# DISPATCH_SCORING_WEIGHT_RESERVE=0.3

# ── Retention ───────────────────────────────────────────────────────────────
# Days to retain message history before cleanup (default: 90)
# MESSAGE_HISTORY_RETENTION_DAYS=90

# ── Rate Limiting (Task 11.1) ──────────────────────────────────────────────
# Rate limits are hardcoded per route via @fastify/rate-limit (global: false).
# Uncomment to override in future if env-based config is wired up.
# DISPATCH_RATE_LIMIT_LOGIN_PER_MIN=5
# DISPATCH_RATE_LIMIT_ENQUEUE_PER_MIN=300

# ── HMAC Verification (Task 11.2) ──────────────────────────────────────────
# When true, oralsin webhooks without X-Dispatch-Signature are rejected (401).
# Default false until Oralsin client is signing. Coordinate flip with Oralsin team.
# PLUGIN_ORALSIN_HMAC_REQUIRED=false

# ── Key Rotation (Task 11.4) ───────────────────────────────────────────────
# Run via: pnpm tsx scripts/rotate-keys.ts --all-plugins --core
# Schedule monthly via cron on Kali. Audit log captures every rotation.

# ── OpenTelemetry Tracing (Task 5.1) ────────────────────────────────────────
# Enable telemetry. Set to true OR set OTEL_EXPORTER_OTLP_ENDPOINT.
# OTEL_ENABLED=false

# OTLP HTTP endpoint for trace export. Default: http://127.0.0.1:4318/v1/traces
# Setting this variable also enables telemetry (no need to set OTEL_ENABLED separately).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318/v1/traces

# Service name reported to Jaeger. Default: dispatch-core.
# OTEL_SERVICE_NAME=dispatch-core

# ── Ban Prediction (Task 12.2 — experimental) ──────────────────────────────
# Enable the Frida-fed ban prediction daemon. Listens on 127.0.0.1:9871 for
# line-delimited JSON events from hook scripts. When a device emits N suspect
# events within window, preemptively opens the circuit breaker.
# DISPATCH_BAN_PREDICTION_ENABLED=false
# DISPATCH_BAN_PREDICTION_PORT=9871
# DISPATCH_BAN_PREDICTION_SUSPECT_THRESHOLD=3
# DISPATCH_BAN_PREDICTION_WINDOW_MS=60000


# ── Critical Alerts (Task 10.3) ─────────────────────────────────────────────
# When set, dispatch-core sends structured rich alerts on critical events
# (circuit opened, number_invalid, high failure rate, ban prediction, etc.).
# Both channels are independent — set either or both.

# Slack Incoming Webhook URL.
# DISPATCH_ALERT_SLACK_WEBHOOK=https://hooks.slack.com/services/...

# Telegram bot token (from @BotFather).
# DISPATCH_ALERT_TELEGRAM_BOT_TOKEN=

# Target chat/channel ID (e.g. -1003942208119 for a supergroup).
# DISPATCH_ALERT_TELEGRAM_CHAT_ID=

# Optional supergroup topic ID. Look for /<NUM> in the topic URL.
# DISPATCH_ALERT_TELEGRAM_THREAD_ID=

# Failure-rate threshold per hour that triggers an alert. Default 100.
# DISPATCH_ALERT_FAILURE_THRESHOLD=100
