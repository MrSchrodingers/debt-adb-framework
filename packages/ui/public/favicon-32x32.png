    <title>DEBT | Cobrança Empresarial e Recuperação de Crédito</title>
    <meta name="description" content="DEBT: cobrança empresarial e recuperação de crédito preservando o relacionamento com seus clientes. Parceira estratégica de grandes instituições no Brasil." />
    <meta name="keywords" content="recuperacao de credito, cobranca, inadimplencia, seguradora, cooperativa, instituicao financeira, HDI, Liberty, Yelum, Sicoob" />

    <!-- Favicons -->
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#1E3F66">
    <meta name="msapplication-TileColor" content="#1E3F66">
    <meta name="theme-color" content="#1E3F66">
    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">

    <!-- Canonical & Language são gerenciados pelo React Helmet em cada página -->

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "DEBT Cobranças Empresariais",
      "image": "https://debt.com.br/images/Logo Branco.webp",
      "description": "Recuperação de crédito empresarial e cobrança com tecnologia e soluções personalizadas. Parceira estratégica de grandes instituições para otimização do fluxo de caixa e redução de inadimplência.",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Avenida Paraná, 453, Sala 505",
        "addressLocality": "Londrina",
        "addressRegion": "PR",
        "postalCode": "86010-922",
        "addressCountry": "BR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": -23.311288,
        "longitude": -51.159502
      },
      "url": "https://debt.com.br/",
      "telephone": ["+55 43 3378-5450", "0800 400 5450"],
      "email": "contato@debt.com.br",
      "openingHours": ["Seg-Sex 09:00-18:00"],
      "priceRange": "Sob consulta",
      "makesOffer": [
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Parceria com HDI, Liberty, Yelum, Sompo, Oral Sin, Sicoob"
          }
        }
      ]
    }
    </script>

    <!-- Schema Organization -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "DEBT",
      "legalName": "DEBT Cobranças Empresariais Ltda",
