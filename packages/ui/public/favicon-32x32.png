    <!-- Schema Service - Serviços oferecidos -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "serviceType": "Recuperação de Crédito Empresarial",
      "provider": {
        "@type": "Organization",
        "name": "DEBT"
      },
      "areaServed": {
        "@type": "Country",
        "name": "Brasil"
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Serviços de Recuperação de Crédito",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Cobrança Amigável",
              "description": "Recuperação de crédito com abordagem humanizada, preservando o relacionamento com seus clientes através de múltiplos canais de comunicação."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Cobrança para Seguradoras",
              "description": "Serviço especializado de ressarcimento e recuperação de valores para seguradoras, com expertise em sinistros e franquias."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Cobrança para Cooperativas",
              "description": "Soluções personalizadas para cooperativas de crédito, respeitando os valores cooperativistas e o relacionamento com associados."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Integração via API",
              "description": "Integração segura e automatizada com seu sistema, em conformidade com a LGPD, para envio e acompanhamento de carteiras."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Dashboard de Acompanhamento",
              "description": "Plataforma completa para acompanhamento em tempo real de métricas, acordos e resultados da recuperação."
            }
          }
        ]
      }
    }
    </script>

    <!-- Schema FAQPage para rich snippets -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Quanto custa o serviço da DEBT?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Trabalhamos com modelo de remuneração por performance. Isso significa que você só paga quando recuperamos seu dinheiro. Sem taxas fixas, sem mensalidades. Zero risco para sua empresa."
          }
        },
        {
          "@type": "Question",
          "name": "Como vocês preservam o relacionamento com meu cliente?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Nossa abordagem é humanizada e respeitosa. Usamos múltiplos canais (WhatsApp, e-mail, telefone) e linguagem adequada ao perfil do devedor. O objetivo é recuperar o crédito E manter a porta aberta para novos negócios."
          }
        },
        {
          "@type": "Question",
          "name": "Em quanto tempo vejo resultados?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Os primeiros acordos costumam acontecer em até 15 dias após recebermos sua carteira. Você acompanha tudo em tempo real pelo dashboard e recebe relatórios semanais de performance."
          }
        },
        {
          "@type": "Question",
          "name": "Vocês atendem empresas de qualquer tamanho?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sim! Embora tenhamos expertise com grandes instituições, oferecemos soluções personalizadas para empresas de todos os portes. Entre em contato para avaliarmos sua necessidade."
          }
        },
        {
          "@type": "Question",
          "name": "Como funciona a integração com meu sistema?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Desenvolvemos integrações seguras e personalizadas via API. Seus dados são enviados de forma automatizada e protegida, em total conformidade com a LGPD."
          }
        },
        {
          "@type": "Question",
          "name": "Posso acompanhar os resultados em tempo real?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sim! Você terá acesso a um dashboard completo com métricas de recuperação, acordos fechados, parcelas recebidas e muito mais. Também enviamos relatórios semanais personalizados."
          }
        }
      ]
    }
    </script>

