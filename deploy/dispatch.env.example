# Dispatch ADB Framework — Environment Configuration
# Copy this file to /opt/dispatch/.env and fill in the values

# Server
PORT=7890
NODE_ENV=production
DB_PATH=/opt/dispatch/data/dispatch.db

# API Authentication
DISPATCH_API_KEY=change-me-to-a-secure-key
DISPATCH_ALLOWED_ORIGINS=http://localhost:5173

# WAHA Integration
WAHA_API_URL=https://your-waha-server.example.com
WAHA_API_KEY=
WAHA_WEBHOOK_HMAC_SECRET=

# Dispatch webhook URL (for WAHA to call back)
DISPATCH_WEBHOOK_URL=http://localhost:7890/api/v1/webhooks/waha

# Chatwoot Integration (optional)
CHATWOOT_API_URL=
CHATWOOT_API_TOKEN=
CHATWOOT_ACCOUNT_ID=1

# Plugin: Oralsin
DISPATCH_PLUGINS=oralsin
PLUGIN_ORALSIN_WEBHOOK_URL=https://gestao.debt.com.br/api/v1/webhooks/dispatch/callback/
PLUGIN_ORALSIN_API_KEY=
PLUGIN_ORALSIN_HMAC_SECRET=

# ── Alerts (Task 10.3) ─────────────────────────────────────────────────────
# DISPATCH_ALERT_SLACK_WEBHOOK=https://hooks.slack.com/services/...
# DISPATCH_ALERT_TELEGRAM_BOT_TOKEN=
# DISPATCH_ALERT_TELEGRAM_CHAT_ID=
# DISPATCH_ALERT_FAILURE_THRESHOLD=100

# Logging
LOG_FILE=/opt/dispatch/logs/dispatch.log

# Message History
MESSAGE_HISTORY_RETENTION_DAYS=90
